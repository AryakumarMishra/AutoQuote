# Copy this file to .env and fill in your real Qwen Cloud key before going live.
# Leave MOCK_MODE=true while you're building pipeline logic -- it costs zero credits.

DASHSCOPE_API_KEY=your-qwen-cloud-api-key-here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Cheap model for high-volume parsing/extraction work
QWEN_MODEL_PARSE=qwen-turbo
# Cheap model for the sanitizer's LLM-based classification pass
QWEN_MODEL_SANITIZE=qwen-turbo
# Slightly stronger model for the judgment call that decides auto-send vs human review
QWEN_MODEL_RISK=qwen-plus

# When true, every Qwen call is replaced with a deterministic mock response.
# Flip to false only once you're ready to spend real credits.
MOCK_MODE=true

# Above this quote value (in USD), always route to human approval regardless of risk score
HIGH_VALUE_THRESHOLD_USD=2000